# PATH (runs for login + non-interactive; keep deterministic)
fish_add_path -m $HOME/.bin

# --- Homebrew Prefix ---
{{ if eq .chezmoi.os "darwin" -}}
set -l brew_prefix /opt/homebrew
{{ else if eq .chezmoi.os "linux" -}}
# Check for global install first, then fall back to home directory
if test -d /home/linuxbrew/.linuxbrew
    set brew_prefix /home/linuxbrew/.linuxbrew
else
    set brew_prefix ~/.linuxbrew
end
{{ end -}}

# --- Homebrew Path Configuration ---
if test -d "$brew_prefix"
    set -gx HOMEBREW_NO_ANALYTICS 1
    set -gx HOMEBREW_AUTO_UPDATE_SECS 86400

    # We add paths and move them to the front (-m) to prioritize Brew binaries
    fish_add_path -m \
        $brew_prefix/sbin \
        $brew_prefix/bin \
        {{ if eq .chezmoi.os "darwin" -}}
        $brew_prefix/opt/python/libexec/bin \
        $brew_prefix/opt/coreutils/libexec/gnubin \
        {{ end -}}
        # The line below is a 'no-op' to ensure the trailing backslash doesn't break
        $brew_prefix/bin 
end

if command -q chezmoi
    set -l _czm_src (chezmoi source-path 2>/dev/null)
    if test -n "$_czm_src" -a -d "$_czm_src/bin"
        fish_add_path -m "$_czm_src/bin"
    end
end

set -gx GOPATH $HOME/.go
fish_add_path -m $GOPATH/bin $HOME/.cargo/bin
