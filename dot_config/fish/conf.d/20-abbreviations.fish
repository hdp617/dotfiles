# Interactive abbreviations and simple aliases
status is-interactive; or exit 0

abbr -a -- g gcloud
abbr -a -- k kubectl
abbr -a -- tf terraform

alias ls='ls --color=auto'
alias ll='ls -lah'
alias la='ls -A'
alias l=ls
alias grep='grep --color=auto'
alias cp='cp -i'
alias mv='mv -i'
alias gag='git exec ag'
alias mirrorsite='wget -m -k -K -E -e robots=off'
