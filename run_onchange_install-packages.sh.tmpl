{{- if eq .chezmoi.os "darwin" -}}
#!/bin/sh
# Install packages from the chezmoi-managed ~/.Brewfile (dot_Brewfile).
# Do not run `brew bundle dump` here: with mode=symlink that would overwrite
# the source Brewfile with whatever happens to be installed on this machine.
set -eu
command -v brew >/dev/null 2>&1 || {
  echo "homebrew not found; cannot install packages" >&2
  exit 1
}
brew bundle --global
{{- end -}}
