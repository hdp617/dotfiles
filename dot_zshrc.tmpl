# Legacy zsh init (optional). Primary shell: Fish (~/.config/fish); see README.
# Functions
source ~/.shell/functions.sh

# PATH: user bin (~/.local/bin), then Homebrew (macOS only)
path_prepend "$HOME/.local/bin"

{{ if eq .chezmoi.os "darwin" -}}
export HOMEBREW_NO_ANALYTICS=1
export HOMEBREW_AUTO_UPDATE_SECS=86400
brew_prefix='/opt/homebrew'
path_prepend "$brew_prefix/sbin"
path_prepend "$brew_prefix/bin"
path_prepend "$brew_prefix/opt/coreutils/libexec/gnubin"
path_prepend "$brew_prefix/opt/python/libexec/bin"
{{ end }}

# External plugins (initialized before)
source ~/.zsh/plugins_before.zsh

# Settings
source ~/.zsh/settings.zsh

# External settings
source ~/.shell/external.sh

# Aliases
source ~/.shell/aliases.sh

# Custom prompt
source ~/.zsh/prompt.zsh

# External plugins (initialized after)
source ~/.zsh/plugins_after.zsh

# Dev tool paths (chezmoi repo bin, Go, Rust)
if command -v chezmoi >/dev/null 2>&1; then
	_czm_src="$(chezmoi source-path 2>/dev/null)"
	if [[ -n $_czm_src && -d $_czm_src/bin ]]; then
		path_prepend "$_czm_src/bin"
	fi
	unset _czm_src
fi

export GOPATH="$HOME/.go"
path_prepend "$GOPATH/bin"
path_prepend "$HOME/.cargo/bin"

load_secret 'GEMINI_API_KEY' 2>/dev/null || true

# Optional machine-only overrides (not managed by chezmoi)
if [ -f ~/.zshrc.local ]; then
	source ~/.zshrc.local
fi
